# ══════════════════════════════
# ТЕЛЕФОНИЯ — Манго Офис
# ══════════════════════════════
MANGO_API_KEY=
MANGO_API_SALT=
MANGO_WEBHOOK_SECRET=

# ══════════════════════════════
# STT — Яндекс SpeechKit
# ══════════════════════════════
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_STT_MODEL=general
YANDEX_STT_LANGUAGE=ru-RU
YANDEX_STT_SAMPLE_RATE=8000

# ══════════════════════════════
# TTS — Яндекс SpeechKit
# ══════════════════════════════
YANDEX_TTS_VOICE=filipp
YANDEX_TTS_SPEED=1.0
YANDEX_TTS_EMOTION=neutral
YANDEX_TTS_SAMPLE_RATE=8000

# ══════════════════════════════
# LLM — Anthropic Claude
# ══════════════════════════════
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=1500
AI_TEMPERATURE=0.1
AI_TIMEOUT_SEC=10

# ══════════════════════════════
# 1С HTTP-СЕРВИС
# ══════════════════════════════
ONEC_BASE_URL=http://localhost:8080/base/hs/api/v1
ONEC_USERNAME=api_user
ONEC_PASSWORD=
ONEC_TIMEOUT_SEC=5
ONEC_MAX_RETRIES=3

# ══════════════════════════════
# САКУРА CRM
# ══════════════════════════════
SAKURA_BASE_URL=https://sakura.your-company.ru/api/v1
SAKURA_API_KEY=
SAKURA_TIMEOUT_SEC=5

# ══════════════════════════════
# БАЗЫ ДАННЫХ
# ══════════════════════════════
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_ecosystem
REDIS_URL=redis://localhost:6379/0

# ══════════════════════════════
# ВЕКТОРНАЯ БД — Qdrant
# ══════════════════════════════
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ══════════════════════════════
# ХРАНИЛИЩЕ — S3
# ══════════════════════════════
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_CALLS=voice-agent-calls

# ══════════════════════════════
# УВЕДОМЛЕНИЯ
# ══════════════════════════════
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
SMSC_LOGIN=
SMSC_PASSWORD=
SMS_SENDER_NAME=1C-Company

# ══════════════════════════════
# ПРИЛОЖЕНИЕ
# ══════════════════════════════
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_SECRET_KEY=change-me-in-production
WORKING_HOURS_START=09:00
WORKING_HOURS_END=19:00
WORKING_TIMEZONE=Europe/Moscow
DEDUPLICATION_WINDOW_MINUTES=30
ESCALATION_CONFIDENCE_THRESHOLD=0.65
LOW_CONFIDENCE_FLAG_THRESHOLD=0.80
