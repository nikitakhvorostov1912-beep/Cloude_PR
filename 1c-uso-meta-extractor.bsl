// =============================================================
// СБОРЩИК МЕТАДАННЫХ 1С:ERP УСО 2.5
// Запускать в: Администрирование → Консоль кода
// Результат: текстовый отчёт со всеми объектами конфигурации
// =============================================================

Перем ТекстРезультата;

Процедура Разделитель(Заголовок)
	ТекстРезультата = ТекстРезультата + "
|
|=== " + Заголовок + " ===
|";
КонецПроцедуры

Процедура Строка(Текст)
	ТекстРезультата = ТекстРезультата + Текст + "
|";
КонецПроцедуры

ТекстРезультата = "МЕТАДАННЫЕ 1С:ERP УСО — СКВОЗНОЙ ПРИМЕР
|Дата выгрузки: " + Формат(ТекущаяДата(), "ДЛФ=ДТ") + "
|Конфигурация: " + Метаданные.Имя + " / " + Метаданные.Синоним + "
|Версия: " + Метаданные.Версия + "
|";

// =============================================================
// 1. ПОДСИСТЕМЫ (разделы меню верхнего уровня)
// =============================================================
Разделитель("ПОДСИСТЕМЫ (разделы меню)");

Для Каждого Подсистема Из Метаданные.Подсистемы Цикл
	Строка("РАЗДЕЛ: " + Подсистема.Синоним + " [" + Подсистема.Имя + "]");

	// Подразделы второго уровня
	Для Каждого ПодПодсистема Из Подсистема.Подсистемы Цикл
		Строка("  └─ " + ПодПодсистема.Синоним + " [" + ПодПодсистема.Имя + "]");

		// Подразделы третьего уровня
		Для Каждого Уровень3 Из ПодПодсистема.Подсистемы Цикл
			Строка("       └─ " + Уровень3.Синоним + " [" + Уровень3.Имя + "]");
		КонецЦикла;
	КонецЦикла;
КонецЦикла;

// =============================================================
// 2. ДОКУМЕНТЫ — полный список с синонимами
// =============================================================
Разделитель("ДОКУМЕНТЫ (имя объекта → синоним)");

// Ключевые слова для фильтрации строительных документов
МассивКлючей = Новый Массив;
МассивКлючей.Добавить("Строит");
МассивКлючей.Добавить("КС");
МассивКлючей.Добавить("Выполнен");
МассивКлючей.Добавить("Подряд");
МассивКлючей.Добавить("Субподряд");
МассивКлючей.Добавить("Объект");
МассивКлючей.Добавить("Смета");
МассивКлючей.Добавить("Расход");
МассивКлючей.Добавить("Передач");
МассивКлючей.Добавить("Реализаци");
МассивКлючей.Добавить("Приобретение");
МассивКлючей.Добавить("Заказ");
МассивКлючей.Добавить("Поступлен");
МассивКлючей.Добавить("Списание");
МассивКлючей.Добавить("Взаимозачёт");
МассивКлючей.Добавить("Зачёт");
МассивКлючей.Добавить("Акт");
МассивКлючей.Добавить("Закрытие");
МассивКлючей.Добавить("Принятие");

Строка("--- ВСЕ СТРОИТЕЛЬНЫЕ И ЗАКУПОЧНЫЕ ДОКУМЕНТЫ ---");
Для Каждого Документ Из Метаданные.Документы Цикл
	СинонимДок = Документ.Синоним;
	ИмяДок     = Документ.Имя;

	// Проверяем вхождение ключевых слов
	Релевантен = Ложь;
	Для Каждого Ключ Из МассивКлючей Цикл
		Если СтрНайти(ВРег(СинонимДок), ВРег(Ключ)) > 0
			ИЛИ СтрНайти(ВРег(ИмяДок), ВРег(Ключ)) > 0 Тогда
			Релевантен = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Если Релевантен Тогда
		Строка("  ★ " + ИмяДок + "  →  " + СинонимДок);
	КонецЕсли;
КонецЦикла;

Строка("");
Строка("--- ВСЕ ДОКУМЕНТЫ КОНФИГУРАЦИИ (полный список) ---");
Для Каждого Документ Из Метаданные.Документы Цикл
	Строка(Документ.Имя + "  |  " + Документ.Синоним);
КонецЦикла;

// =============================================================
// 3. СПРАВОЧНИКИ — строительные
// =============================================================
Разделитель("СПРАВОЧНИКИ (строительные)");

КлючиСпр = Новый Массив;
КлючиСпр.Добавить("Строит");
КлючиСпр.Добавить("Объект");
КлючиСпр.Добавить("Смета");
КлючиСпр.Добавить("Выполнен");
КлючиСпр.Добавить("Вид работ");
КлючиСпр.Добавить("ВидРаб");
КлючиСпр.Добавить("Этап");
КлючиСпр.Добавить("Направлени");
КлючиСпр.Добавить("Портфель");
КлючиСпр.Добавить("Проект");

Для Каждого Справочник Из Метаданные.Справочники Цикл
	Для Каждого Ключ Из КлючиСпр Цикл
		Если СтрНайти(ВРег(Справочник.Синоним), ВРег(Ключ)) > 0
			ИЛИ СтрНайти(ВРег(Справочник.Имя), ВРег(Ключ)) > 0 Тогда
			Строка("  " + Справочник.Имя + "  →  " + Справочник.Синоним);
			Прервать;
		КонецЕсли;
	КонецЦикла;
КонецЦикла;

// =============================================================
// 4. РЕГИСТРЫ НАКОПЛЕНИЯ — строительные
// =============================================================
Разделитель("РЕГИСТРЫ НАКОПЛЕНИЯ (строительные)");

Для Каждого Рег Из Метаданные.РегистрыНакопления Цикл
	Если СтрНайти(ВРег(Рег.Синоним), "СТРОИТ") > 0
		ИЛИ СтрНайти(ВРег(Рег.Имя), "СТРОИТ") > 0
		ИЛИ СтрНайти(ВРег(Рег.Синоним), "ВЫПОЛНЕН") > 0
		ИЛИ СтрНайти(ВРег(Рег.Синоним), "ОБЪЕКТ") > 0
		ИЛИ СтрНайти(ВРег(Рег.Имя), "ОБЪЕКТ") > 0 Тогда
		Строка("  " + Рег.Имя + "  →  " + Рег.Синоним + "  [" + ?(Рег.ВидРегистра = ВидРегистраНакопления.Остатки, "Остатки", "Обороты") + "]");
	КонецЕсли;
КонецЦикла;

// =============================================================
// 5. РЕКВИЗИТЫ КЛЮЧЕВЫХ ДОКУМЕНТОВ
//    Ищем по точным именам из нашей базы знаний
// =============================================================
Разделитель("РЕКВИЗИТЫ КЛЮЧЕВЫХ ДОКУМЕНТОВ");

// Список документов для детального анализа
ИменаДляАнализа = Новый Массив;
ИменаДляАнализа.Добавить("РеализацияСтроительныхРабот");
ИменаДляАнализа.Добавить("УчётВыполненныхРабот");
ИменаДляАнализа.Добавить("АктОПриёмкеВыполненныхРаботСубподрядчика");
ИменаДляАнализа.Добавить("РасходМатериаловВСтроительстве");
ИменаДляАнализа.Добавить("ПередачаМатериаловВПроизводство");
ИменаДляАнализа.Добавить("ПриобретениеТоваровУслуг");
ИменаДляАнализа.Добавить("ЗаказПоставщику");
ИменаДляАнализа.Добавить("ЗаказПокупателя");
ИменаДляАнализа.Добавить("ЗаявкаНаРасходованиеДенежныхСредств");
ИменаДляАнализа.Добавить("СписаниеБезналичныхДС");
ИменаДляАнализа.Добавить("ПоступлениеБезналичныхДС");
ИменаДляАнализа.Добавить("ВзаимозачётЗадолженности");

Для Каждого ИмяДок Из ИменаДляАнализа Цикл
	МетаДок = Метаданные.Документы.Найти(ИмяДок);
	Если МетаДок <> Неопределено Тогда
		Строка("");
		Строка("▶ " + МетаДок.Имя + " / " + МетаДок.Синоним);

		// Реквизиты шапки
		Строка("  Реквизиты:");
		Для Каждого Рекв Из МетаДок.Реквизиты Цикл
			Строка("    - " + Рекв.Имя + " : " + Рекв.Синоним + "  [" + Рекв.Тип + "]");
		КонецЦикла;

		// Табличные части
		Если МетаДок.ТабличныеЧасти.Количество() > 0 Тогда
			Строка("  Табличные части:");
			Для Каждого ТЧ Из МетаДок.ТабличныеЧасти Цикл
				Строка("    [" + ТЧ.Имя + " / " + ТЧ.Синоним + "]");
				Для Каждого КолТЧ Из ТЧ.Реквизиты Цикл
					Строка("      - " + КолТЧ.Имя + " : " + КолТЧ.Синоним);
				КонецЦикла;
			КонецЦикла;
		КонецЕсли;

		// В каких подсистемах числится документ
		Строка("  Подсистемы (меню):");
		Для Каждого Подсистема Из МетаДок.ПодсистемыВКоторыхУчаствует Цикл
			Строка("    → " + Подсистема.Синоним + " [" + Подсистема.Полное Имя + "]");
		КонецЦикла;

	Иначе
		Строка("");
		Строка("✗ НЕ НАЙДЕН: " + ИмяДок);
	КонецЕсли;
КонецЦикла;

// =============================================================
// 6. ПОИСК ДОКУМЕНТОВ ПО ВСЕМ ВОЗМОЖНЫМ ИМЕНАМ (для не найденных)
// =============================================================
Разделитель("ПОИСК: все документы содержащие 'Внутренн' или 'Заказ'");

Для Каждого Документ Из Метаданные.Документы Цикл
	Если СтрНайти(ВРег(Документ.Синоним), "ВНУТРЕНН") > 0
		ИЛИ СтрНайти(ВРег(Документ.Имя), "ВНУТРЕНН") > 0
		ИЛИ (СтрНайти(ВРег(Документ.Синоним), "ЗАКАЗ") > 0)
		ИЛИ (СтрНайти(ВРег(Документ.Имя), "ЗАКАЗ") > 0) Тогда
		Строка("  " + Документ.Имя + "  |  " + Документ.Синоним);
	КонецЕсли;
КонецЦикла;

// =============================================================
// 7. СПРАВОЧНИК СТРУКТУРЫ ПРЕДПРИЯТИЯ
// =============================================================
Разделитель("СПРАВОЧНИК: структура предприятия (точное имя)");

СпрПред = Метаданные.Справочники.Найти("СтруктураПредприятия");
Если СпрПред <> Неопределено Тогда
	Строка("НАЙДЕН: " + СпрПред.Имя + " / " + СпрПред.Синоним);
	Для Каждого Рекв Из СпрПред.Реквизиты Цикл
		Если СтрНайти(ВРег(Рекв.Синоним), "ПРОИЗ") > 0
			ИЛИ СтрНайти(ВРег(Рекв.Имя), "ПРОИЗ") > 0 Тогда
			Строка("  ★ Флаг производства: " + Рекв.Имя + " / " + Рекв.Синоним);
		КонецЕсли;
	КонецЦикла;
Иначе
	Строка("НЕ НАЙДЕН: СтруктураПредприятия — ищем похожие...");
	Для Каждого Спр Из Метаданные.Справочники Цикл
		Если СтрНайти(ВРег(Спр.Синоним), "СТРУКТУР") > 0
			ИЛИ СтрНайти(ВРег(Спр.Синоним), "ПОДРАЗДЕЛЕН") > 0 Тогда
			Строка("  ~ " + Спр.Имя + "  /  " + Спр.Синоним);
		КонецЕсли;
	КонецЦикла;
КонецЕсли;

// =============================================================
// 8. ВЫВОД РЕЗУЛЬТАТА
// =============================================================
Сообщить(ТекстРезультата);

