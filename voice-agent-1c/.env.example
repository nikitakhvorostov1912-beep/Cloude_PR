# === Voice Agent 1C — Environment Variables ===

# Телефония (Манго Офис)
MANGO_API_KEY=
MANGO_API_SALT=
MANGO_WEBHOOK_SECRET=

# 1С HTTP-сервис
ONEC_BASE_URL=http://your-1c-server/api/v1
ONEC_USERNAME=
ONEC_PASSWORD=

# База данных
DATABASE_URL=postgresql+asyncpg://voice_agent:voice_agent@localhost:5432/voice_agent

# Redis
REDIS_URL=redis://localhost:6379

# AI (Phase 2)
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=1000

# Яндекс SpeechKit (Phase 2)
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# Уведомления (Phase 3)
TELEGRAM_BOT_TOKEN=
TELEGRAM_SUPPORT_CHAT_ID=
SMSC_LOGIN=
SMSC_PASSWORD=

# Хранилище (Phase 4)
S3_BUCKET=voice-agent-calls
S3_ENDPOINT=https://storage.yandexcloud.net
