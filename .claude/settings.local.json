{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(git status -u)",
      "Bash(gh repo:*)",
      "Bash(npm install:*)",
      "Bash(npm run build)",
      "Bash(npm run tauri build)",
      "Bash(npm list:*)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx vite build)",
      "Bash(pip install:*)",
      "Bash(python -c \":*)",
      "Bash(py -3 -c \":*)",
      "mcp__Claude_Preview__preview_start",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:developer.chrome.com)",
      "Bash(gh api:*)",
      "Bash(git clone:*)",
      "Bash(powershell -Command \"Get-PnpDevice -Class AudioEndpoint -Status OK | Select-Object FriendlyName, Status, InstanceId | Format-Table -AutoSize\")",
      "Bash(powershell -Command \"Get-PnpDevice | Where-Object {$_Class -eq ''AudioEndpoint''} | Select-Object FriendlyName, Status | Format-Table -AutoSize\")",
      "Bash(powershell -Command \"Get-CimInstance Win32_SoundDevice | Select-Object Name, Status, StatusInfo | Format-Table -AutoSize\")"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash D:/Cloude_PR/.claude/hooks-handlers/session-boot.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash D:/Cloude_PR/.claude/hooks-handlers/session-resume.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
