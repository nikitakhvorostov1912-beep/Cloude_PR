// =============================================================
// БЫСТРЫЙ ПОИСК ОБЪЕКТА В МЕТАДАННЫХ
// ─────────────────────────────────────────────────────────────
// ГДЕ ЗАПУСКАТЬ: Все функции → Стандартные → Консоль кода
// КАК: поменяй ЧтоИщем → Выполнить (Ctrl+Enter)
// =============================================================

ЧтоИщем = "Заказ";  // ← МЕНЯТЬ СЮДА (часть имени или синонима на русском)

Рез = "Поиск: """ + ЧтоИщем + """" + Символы.ПС;
ЧтоВРег = ВРег(ЧтоИщем);

// Документы
Рез = Рез + Символы.ПС + "=== ДОКУМЕНТЫ ===" + Символы.ПС;
Для Каждого Д Из Метаданные.Документы Цикл
	Если СтрНайти(ВРег(Д.Имя), ЧтоВРег) > 0
		ИЛИ СтрНайти(ВРег(Д.Синоним), ЧтоВРег) > 0 Тогда
		Рез = Рез + "  Документ." + Д.Имя + "  ->  " + Д.Синоним + Символы.ПС;
		Для Каждого ПС Из Метаданные.ПодсистемыВКоторыхУчаствует(Д) Цикл
			Рез = Рез + "     Меню: " + ПС.ПолноеИмя + Символы.ПС;
		КонецЦикла;
	КонецЕсли;
КонецЦикла;

// Справочники
Рез = Рез + Символы.ПС + "=== СПРАВОЧНИКИ ===" + Символы.ПС;
Для Каждого С Из Метаданные.Справочники Цикл
	Если СтрНайти(ВРег(С.Имя), ЧтоВРег) > 0
		ИЛИ СтрНайти(ВРег(С.Синоним), ЧтоВРег) > 0 Тогда
		Рез = Рез + "  Справочник." + С.Имя + "  ->  " + С.Синоним + Символы.ПС;
	КонецЕсли;
КонецЦикла;

// Регистры накопления
Рез = Рез + Символы.ПС + "=== РЕГИСТРЫ НАКОПЛЕНИЯ ===" + Символы.ПС;
Для Каждого Р Из Метаданные.РегистрыНакопления Цикл
	Если СтрНайти(ВРег(Р.Имя), ЧтоВРег) > 0
		ИЛИ СтрНайти(ВРег(Р.Синоним), ЧтоВРег) > 0 Тогда
		ВидРег = ?(Р.ВидРегистра = ВидРегистраНакопления.Остатки, "Остатки", "Обороты");
		Рез = Рез + "  " + Р.Имя + "  ->  " + Р.Синоним + "  [" + ВидРег + "]" + Символы.ПС;
	КонецЕсли;
КонецЦикла;

// Регистры сведений
Рез = Рез + Символы.ПС + "=== РЕГИСТРЫ СВЕДЕНИЙ ===" + Символы.ПС;
Для Каждого Р Из Метаданные.РегистрыСведений Цикл
	Если СтрНайти(ВРег(Р.Имя), ЧтоВРег) > 0
		ИЛИ СтрНайти(ВРег(Р.Синоним), ЧтоВРег) > 0 Тогда
		Рез = Рез + "  " + Р.Имя + "  ->  " + Р.Синоним + Символы.ПС;
	КонецЕсли;
КонецЦикла;

Сообщить(Рез);
