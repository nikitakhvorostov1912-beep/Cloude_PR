// =============================================================
// СБОРЩИК МЕТАДАННЫХ 1С:ERP УСО 2.5
// ─────────────────────────────────────────────────────────────
// ГДЕ ЗАПУСКАТЬ:
//   Главное меню → Все функции → Стандартные → Консоль кода
//   (НЕ «Консоль запросов»!)
//
//   Если «Все функции» нет в меню:
//   Сервис → Параметры → установить галку «Показывать команду Все функции»
//
// КАК ЗАПУСТИТЬ: вставить весь текст → кнопка «Выполнить» (Ctrl+Enter)
// РЕЗУЛЬТАТ: в окне «Сообщения» появится полный список объектов
// =============================================================

Перем ТекстРезультата;

// ── Вспомогательные процедуры ─────────────────────────────────

Процедура Разд(Заголовок)
	ТекстРезультата = ТекстРезультата
		+ Символы.ПС + "═══ " + Заголовок + " ═══" + Символы.ПС;
КонецПроцедуры

Процедура Стр(Текст)
	ТекстРезультата = ТекстРезультата + Текст + Символы.ПС;
КонецПроцедуры

// ── Заголовок ─────────────────────────────────────────────────

ТекстРезультата =
	"МЕТАДАННЫЕ: " + Метаданные.Синоним
	+ " / ver " + Метаданные.Версия
	+ " / " + Формат(ТекущаяДата(), "ДЛФ=ДТ")
	+ Символы.ПС;

// =============================================================
// 1. РАЗДЕЛЫ МЕНЮ (подсистемы)
// =============================================================
Разд("РАЗДЕЛЫ МЕНЮ — верхний уровень");

Для Каждого ПС1 Из Метаданные.Подсистемы Цикл
	Стр("▶ " + ПС1.Синоним + "  [" + ПС1.Имя + "]");
	Для Каждого ПС2 Из ПС1.Подсистемы Цикл
		Стр("   └─ " + ПС2.Синоним + "  [" + ПС2.Имя + "]");
		Для Каждого ПС3 Из ПС2.Подсистемы Цикл
			Стр("         └─ " + ПС3.Синоним + "  [" + ПС3.Имя + "]");
		КонецЦикла;
	КонецЦикла;
КонецЦикла;

// =============================================================
// 2. ВСЕ ДОКУМЕНТЫ — имя объекта и синоним
// =============================================================
Разд("ВСЕ ДОКУМЕНТЫ (имяОбъекта → синоним)");

Для Каждого Д Из Метаданные.Документы Цикл
	Стр(Д.Имя + "  |  " + Д.Синоним);
КонецЦикла;

// =============================================================
// 3. СТРОИТЕЛЬНЫЕ ДОКУМЕНТЫ — + путь в меню
// =============================================================
Разд("СТРОИТЕЛЬНЫЕ ДОКУМЕНТЫ (с путём в меню)");

КлючиДок = "СТРОИТ,КС,ВЫПОЛНЕН,ПОДРЯД,СУБПОДРЯД,ОБЪЕКТ,СМЕТА,РАСХОД,ПЕРЕДАЧ,РЕАЛИЗАЦИ,ПРИОБРЕТЕН,ПОСТУПЛЕН,ВЗАИМОЗАЧ,АКТ ПРИЕМ,ЗАКРЫТИЕ,ПРИНЯТИЕ";
МассивКлючей = СтрРазделить(КлючиДок, ",");

Для Каждого Д Из Метаданные.Документы Цикл
	Релевантен = Ложь;
	Для Каждого К Из МассивКлючей Цикл
		Если СтрНайти(ВРег(Д.Синоним), СокрЛП(К)) > 0
			ИЛИ СтрНайти(ВРег(Д.Имя), СокрЛП(К)) > 0 Тогда
			Релевантен = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Если Не Релевантен Тогда
		Продолжить;
	КонецЕсли;

	Стр("");
	Стр("  ★ " + Д.Имя + "  →  " + Д.Синоним);

	Для Каждого ПС Из Метаданные.ПодсистемыВКоторыхУчаствует(Д) Цикл
		Стр("       Меню: " + ПС.ПолноеИмя);
	КонецЦикла;
КонецЦикла;

// =============================================================
// 4. РЕКВИЗИТЫ КЛЮЧЕВЫХ ДОКУМЕНТОВ (проверка имён объектов)
// =============================================================
Разд("РЕКВИЗИТЫ КЛЮЧЕВЫХ ДОКУМЕНТОВ");

ИменаДляПроверки = СтрРазделить(
	"РеализацияСтроительныхРабот,УчётВыполненныхРабот,АктОПриёмкеВыполненныхРаботСубподрядчика,РасходМатериаловВСтроительстве,ПередачаМатериаловВПроизводство,ПриобретениеТоваровУслуг,ЗаказПоставщику,ЗаявкаНаРасходованиеДенежныхСредств,СписаниеБезналичныхДС,ПоступлениеБезналичныхДС,ВзаимозачётЗадолженности",
	",");

Для Каждого ИмяДок Из ИменаДляПроверки Цикл
	МетаДок = Метаданные.Документы.Найти(СокрЛП(ИмяДок));
	Если МетаДок <> Неопределено Тогда
		Стр("");
		Стр("  НАЙДЕН: " + МетаДок.Имя + "  /  " + МетаДок.Синоним);

		Стр("    Реквизиты шапки:");
		Для Каждого Рекв Из МетаДок.Реквизиты Цикл
			Стр("      " + Рекв.Имя + "  :  " + Рекв.Синоним);
		КонецЦикла;

		Для Каждого ТЧ Из МетаДок.ТабличныеЧасти Цикл
			Стр("    ТЧ [" + ТЧ.Имя + " / " + ТЧ.Синоним + "]:");
			Для Каждого КолТЧ Из ТЧ.Реквизиты Цикл
				Стр("      " + КолТЧ.Имя + "  :  " + КолТЧ.Синоним);
			КонецЦикла;
		КонецЦикла;

		Стр("    Путь в меню:");
		Для Каждого ПС Из Метаданные.ПодсистемыВКоторыхУчаствует(МетаДок) Цикл
			Стр("      -> " + ПС.ПолноеИмя);
		КонецЦикла;
	Иначе
		Стр("  НЕ НАЙДЕН: " + СокрЛП(ИмяДок));
	КонецЕсли;
КонецЦикла;

// =============================================================
// 5. СПРАВОЧНИКИ — строительные + структура предприятия
// =============================================================
Разд("СПРАВОЧНИКИ (строительные)");

КлючиСпр = СтрРазделить("СТРОИТ,ОБЪЕКТ,СМЕТА,ЭТАП,НАПРАВЛЕН,ПОРТФЕЛЬ,ПРОЕКТ,СТРУКТУР,ПОДРАЗДЕЛЕН", ",");

Для Каждого С Из Метаданные.Справочники Цикл
	Для Каждого К Из КлючиСпр Цикл
		Если СтрНайти(ВРег(С.Синоним), СокрЛП(К)) > 0
			ИЛИ СтрНайти(ВРег(С.Имя), СокрЛП(К)) > 0 Тогда
			Стр("  " + С.Имя + "  ->  " + С.Синоним);
			// Ищем флаг "производит продукцию"
			Для Каждого Рекв Из С.Реквизиты Цикл
				Если СтрНайти(ВРег(Рекв.Синоним), "ПРОИЗ") > 0
					ИЛИ СтрНайти(ВРег(Рекв.Имя), "ПРОИЗ") > 0 Тогда
					Стр("    ФЛАГ: " + Рекв.Имя + " / " + Рекв.Синоним);
				КонецЕсли;
			КонецЦикла;
			Прервать;
		КонецЕсли;
	КонецЦикла;
КонецЦикла;

// =============================================================
// 6. РЕГИСТРЫ НАКОПЛЕНИЯ — строительные
// =============================================================
Разд("РЕГИСТРЫ НАКОПЛЕНИЯ (строительные)");

КлючиРег = СтрРазделить("СТРОИТ,ВЫПОЛНЕН,ОБЪЕКТ,СУБПОДРЯД,СМЕТА", ",");

Для Каждого Р Из Метаданные.РегистрыНакопления Цикл
	Для Каждого К Из КлючиРег Цикл
		Если СтрНайти(ВРег(Р.Синоним), СокрЛП(К)) > 0
			ИЛИ СтрНайти(ВРег(Р.Имя), СокрЛП(К)) > 0 Тогда
			ВидРег = ?(Р.ВидРегистра = ВидРегистраНакопления.Остатки, "Остатки", "Обороты");
			Стр("  " + Р.Имя + "  ->  " + Р.Синоним + "  [" + ВидРег + "]");
			Прервать;
		КонецЕсли;
	КонецЦикла;
КонецЦикла;

// =============================================================
// ВЫВОД
// =============================================================
Сообщить(ТекстРезультата);
