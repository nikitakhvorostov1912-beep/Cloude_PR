////////////////////////////////////////////////////////////////////////////////
// ВНЕШНЯЯ ОБРАБОТКА: Сборщик метаданных 1С:ERP УСО 2.5
// Модуль объекта — серверная логика
////////////////////////////////////////////////////////////////////////////////

// ── Вспомогательные ──────────────────────────────────────────────────────────

Функция НоваяСтрока(Текст = "") Экспорт
	Возврат Текст + Символы.ПС;
КонецФункции

Функция Разд(Заголовок) Экспорт
	Возврат Символы.ПС + "═══ " + Заголовок + " ═══" + Символы.ПС;
КонецФункции

// ── Главная функция ───────────────────────────────────────────────────────────

Функция СобратьМетаданные() Экспорт

	Рез = "МЕТАДАННЫЕ: " + Метаданные.Синоним
		+ "  ver." + Метаданные.Версия
		+ "  [" + Формат(ТекущаяДата(), "ДЛФ=ДТ") + "]"
		+ Символы.ПС;

	// ─────────────────────────────────────────────────────────────────────────
	// 1. РАЗДЕЛЫ МЕНЮ (подсистемы 1-3 уровня)
	// ─────────────────────────────────────────────────────────────────────────
	Рез = Рез + Разд("РАЗДЕЛЫ МЕНЮ");

	Для Каждого ПС1 Из Метаданные.Подсистемы Цикл
		Рез = Рез + "▶ " + ПС1.Синоним + "  [" + ПС1.Имя + "]" + Символы.ПС;
		Для Каждого ПС2 Из ПС1.Подсистемы Цикл
			Рез = Рез + "   └─ " + ПС2.Синоним + "  [" + ПС2.Имя + "]" + Символы.ПС;
			Для Каждого ПС3 Из ПС2.Подсистемы Цикл
				Рез = Рез + "         └─ " + ПС3.Синоним + "  [" + ПС3.Имя + "]" + Символы.ПС;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;

	// ─────────────────────────────────────────────────────────────────────────
	// 2. ВСЕ ДОКУМЕНТЫ
	// ─────────────────────────────────────────────────────────────────────────
	Рез = Рез + Разд("ВСЕ ДОКУМЕНТЫ  (ИмяОбъекта  |  Синоним)");

	Для Каждого Д Из Метаданные.Документы Цикл
		Рез = Рез + Д.Имя + "  |  " + Д.Синоним + Символы.ПС;
	КонецЦикла;

	// ─────────────────────────────────────────────────────────────────────────
	// 3. СТРОИТЕЛЬНЫЕ ДОКУМЕНТЫ — с путём в меню и реквизитами
	// ─────────────────────────────────────────────────────────────────────────
	Рез = Рез + Разд("СТРОИТЕЛЬНЫЕ ДОКУМЕНТЫ (имя + меню + реквизиты)");

	Ключи = СтрРазделить("СТРОИТ,КС,ВЫПОЛНЕН,ПОДРЯД,СУБПОДРЯД,ОБЪЕКТ,СМЕТА,РАСХОД,ПЕРЕДАЧ,РЕАЛИЗАЦИ,ПРИОБРЕТЕН,ПОСТУПЛЕН,ВЗАИМОЗАЧ,АКТ,ЗАКРЫТИЕ,ПРИНЯТИЕ", ",");

	Для Каждого Д Из Метаданные.Документы Цикл
		Попал = Ложь;
		Для Каждого К Из Ключи Цикл
			Если СтрНайти(ВРег(Д.Синоним), СокрЛП(К)) > 0
				ИЛИ СтрНайти(ВРег(Д.Имя), СокрЛП(К)) > 0 Тогда
				Попал = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если Не Попал Тогда Продолжить; КонецЕсли;

		Рез = Рез + Символы.ПС + "★ " + Д.Имя + "  /  " + Д.Синоним + Символы.ПС;

		// Путь в меню
		Для Каждого ПС Из Метаданные.ПодсистемыВКоторыхУчаствует(Д) Цикл
			Рез = Рез + "   Меню: " + ПС.ПолноеИмя + Символы.ПС;
		КонецЦикла;

		// Реквизиты шапки
		Рез = Рез + "   Реквизиты:" + Символы.ПС;
		Для Каждого Р Из Д.Реквизиты Цикл
			Рез = Рез + "     - " + Р.Имя + "  :  " + Р.Синоним + Символы.ПС;
		КонецЦикла;

		// Табличные части
		Для Каждого ТЧ Из Д.ТабличныеЧасти Цикл
			Рез = Рез + "   ТЧ [" + ТЧ.Имя + " / " + ТЧ.Синоним + "]:" + Символы.ПС;
			Для Каждого КТЧ Из ТЧ.Реквизиты Цикл
				Рез = Рез + "     - " + КТЧ.Имя + "  :  " + КТЧ.Синоним + Символы.ПС;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;

	// ─────────────────────────────────────────────────────────────────────────
	// 4. ПРОВЕРКА КОНКРЕТНЫХ ДОКУМЕНТОВ из нашей базы знаний
	// ─────────────────────────────────────────────────────────────────────────
	Рез = Рез + Разд("ПРОВЕРКА ИМЁН ДОКУМЕНТОВ (НАЙДЕН / НЕ НАЙДЕН)");

	ИменаПроверки = СтрРазделить(
		"РеализацияСтроительныхРабот,УчётВыполненныхРабот,АктОПриёмкеВыполненныхРаботСубподрядчика,РасходМатериаловВСтроительстве,ПередачаМатериаловВПроизводство,ПриобретениеТоваровУслуг,ЗаказПоставщику,ЗаявкаНаРасходованиеДенежныхСредств,СписаниеБезналичныхДС,ПоступлениеБезналичныхДС,ВзаимозачётЗадолженности",
		",");

	Для Каждого Имя Из ИменаПроверки Цикл
		ИмяЧистое = СокрЛП(Имя);
		Мета = Метаданные.Документы.Найти(ИмяЧистое);
		Если Мета <> Неопределено Тогда
			Рез = Рез + "  [ДА]  " + ИмяЧистое + "  ->  " + Мета.Синоним + Символы.ПС;
		Иначе
			Рез = Рез + "  [НЕТ] " + ИмяЧистое + Символы.ПС;
		КонецЕсли;
	КонецЦикла;

	// ─────────────────────────────────────────────────────────────────────────
	// 5. СПРАВОЧНИКИ — строительные
	// ─────────────────────────────────────────────────────────────────────────
	Рез = Рез + Разд("СПРАВОЧНИКИ (строительные)");

	КлючиС = СтрРазделить("СТРОИТ,ОБЪЕКТ,СМЕТА,ЭТАП,НАПРАВЛЕН,ПОРТФЕЛЬ,ПРОЕКТ,СТРУКТУР,ПОДРАЗДЕЛЕН", ",");

	Для Каждого С Из Метаданные.Справочники Цикл
		Попал = Ложь;
		Для Каждого К Из КлючиС Цикл
			Если СтрНайти(ВРег(С.Синоним), СокрЛП(К)) > 0
				ИЛИ СтрНайти(ВРег(С.Имя), СокрЛП(К)) > 0 Тогда
				Попал = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если Не Попал Тогда Продолжить; КонецЕсли;

		Рез = Рез + "  " + С.Имя + "  ->  " + С.Синоним + Символы.ПС;

		// Ищем флаг "производит продукцию"
		Для Каждого Р Из С.Реквизиты Цикл
			Если СтрНайти(ВРег(Р.Синоним), "ПРОИЗ") > 0
				ИЛИ СтрНайти(ВРег(Р.Имя), "ПРОИЗ") > 0 Тогда
				Рез = Рез + "    ФЛАГ производства: " + Р.Имя + " / " + Р.Синоним + Символы.ПС;
			КонецЕсли;
		КонецЦикла;

		Для Каждого ПС Из Метаданные.ПодсистемыВКоторыхУчаствует(С) Цикл
			Рез = Рез + "    Меню: " + ПС.ПолноеИмя + Символы.ПС;
		КонецЦикла;
	КонецЦикла;

	// ─────────────────────────────────────────────────────────────────────────
	// 6. РЕГИСТРЫ НАКОПЛЕНИЯ — строительные
	// ─────────────────────────────────────────────────────────────────────────
	Рез = Рез + Разд("РЕГИСТРЫ НАКОПЛЕНИЯ (строительные)");

	КлючиР = СтрРазделить("СТРОИТ,ВЫПОЛНЕН,ОБЪЕКТ,СУБПОДРЯД,СМЕТА", ",");

	Для Каждого Р Из Метаданные.РегистрыНакопления Цикл
		Попал = Ложь;
		Для Каждого К Из КлючиР Цикл
			Если СтрНайти(ВРег(Р.Синоним), СокрЛП(К)) > 0
				ИЛИ СтрНайти(ВРег(Р.Имя), СокрЛП(К)) > 0 Тогда
				Попал = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если Не Попал Тогда Продолжить; КонецЕсли;

		ВидРег = ?(Р.ВидРегистра = ВидРегистраНакопления.Остатки, "Остатки", "Обороты");
		Рез = Рез + "  " + Р.Имя + "  ->  " + Р.Синоним + "  [" + ВидРег + "]" + Символы.ПС;
	КонецЦикла;

	Возврат Рез;

КонецФункции
