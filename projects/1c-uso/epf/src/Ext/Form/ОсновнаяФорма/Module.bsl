&НаКлиенте
Процедура Выполнить(Команда)
	СостояниеОбработки("Собираю метаданные конфигурации...");
	ВыполнитьНаСервере();
КонецПроцедуры

&НаСервере
Процедура ВыполнитьНаСервере()
	Объект.Результат = Объект.СобратьМетаданные();
	ЗначениеВРеквизитФормы(Объект, "Объект");

	// Также сохранить в файл
	ПутьФайла = "C:\CLOUDE_PR\projects\1c-uso\output\uso_meta.txt";
	Попытка
		ЗТ = Новый ЗаписьТекста(ПутьФайла, КодировкаТекста.UTF8);
		ЗТ.Записать(Объект.Результат);
		ЗТ.Закрыть();
		ЗаголовокФормы = "Метаданные УСО — сохранено: " + ПутьФайла;
	Исключение
		ЗаголовокФормы = "Метаданные УСО — файл не сохранён (нет доступа)";
	КонецПопытки;
КонецПроцедуры

&НаКлиентеПроцедура СохранитьВФайл(Команда)
	ДиалогСохранения = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	ДиалогСохранения.Фильтр = "Текстовый файл (*.txt)|*.txt";
	ДиалогСохранения.ПолноеИмяФайла = "uso_meta.txt";
	Если ДиалогСохранения.Выбрать() Тогда
		Текст = Элементы.РезультатПоле.ТекстРедактирования;
		ЗТ = Новый ЗаписьТекста(ДиалогСохранения.ПолноеИмяФайла, КодировкаТекста.UTF8);
		ЗТ.Записать(Текст);
		ЗТ.Закрыть();
		ПоказатьОповещениеПользователя("Сохранено", , ДиалогСохранения.ПолноеИмяФайла);
	КонецЕсли;
КонецПроцедуры
