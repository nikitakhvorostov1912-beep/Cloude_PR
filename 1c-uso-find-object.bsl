// =============================================================
// БЫСТРЫЙ ПОИСК ОБЪЕКТА В МЕТАДАННЫХ
// Замени ЧтоИщем на нужное слово и запусти
// =============================================================

ЧтоИщем = "Заказ";  // ← МЕНЯТЬ СЮДА (часть имени или синонима)

Рез = "";
ЧтоВРег = ВРег(ЧтоИщем);

// Документы
Рез = Рез + "=== ДОКУМЕНТЫ ===" + Символы.ПС;
Для Каждого Д Из Метаданные.Документы Цикл
	Если СтрНайти(ВРег(Д.Имя), ЧтоВРег) > 0
		ИЛИ СтрНайти(ВРег(Д.Синоним), ЧтоВРег) > 0 Тогда
		Рез = Рез + "  Документ." + Д.Имя + "  →  "" + Д.Синоним + """ + Символы.ПС;

		// Показать в каком разделе меню
		Для Каждого ПС Из Д.ПодсистемыВКоторыхУчаствует Цикл
			Рез = Рез + "     Меню: " + ПС.Полное Имя + Символы.ПС;
		КонецЦикла;
	КонецЕсли;
КонецЦикла;

// Справочники
Рез = Рез + "=== СПРАВОЧНИКИ ===" + Символы.ПС;
Для Каждого С Из Метаданные.Справочники Цикл
	Если СтрНайти(ВРег(С.Имя), ЧтоВРег) > 0
		ИЛИ СтрНайти(ВРег(С.Синоним), ЧтоВРег) > 0 Тогда
		Рез = Рез + "  Справочник." + С.Имя + "  →  "" + С.Синоним + """ + Символы.ПС;
	КонецЕсли;
КонецЦикла;

// Регистры
Рез = Рез + "=== РЕГИСТРЫ НАКОПЛЕНИЯ ===" + Символы.ПС;
Для Каждого Р Из Метаданные.РегистрыНакопления Цикл
	Если СтрНайти(ВРег(Р.Имя), ЧтоВРег) > 0
		ИЛИ СтрНайти(ВРег(Р.Синоним), ЧтоВРег) > 0 Тогда
		Рез = Рез + "  РегНакопления." + Р.Имя + "  →  "" + Р.Синоним + """ + Символы.ПС;
	КонецЕсли;
КонецЦикла;

Рез = Рез + "=== РЕГИСТРЫ СВЕДЕНИЙ ===" + Символы.ПС;
Для Каждого Р Из Метаданные.РегистрыСведений Цикл
	Если СтрНайти(ВРег(Р.Имя), ЧтоВРег) > 0
		ИЛИ СтрНайти(ВРег(Р.Синоним), ЧтоВРег) > 0 Тогда
		Рез = Рез + "  РегСведений." + Р.Имя + "  →  "" + Р.Синоним + """ + Символы.ПС;
	КонецЕсли;
КонецЦикла;

Сообщить(Рез);
