////////////////////////////////////////////////////////////////////////////////
// ВНЕШНЯЯ ОБРАБОТКА: Очистка доступности видов рабочих центров
// Модуль объекта
////////////////////////////////////////////////////////////////////////////////

Функция СведенияОВнешнейОбработке() Экспорт

	ПараметрыРегистрации = Новый Структура;
	ПараметрыРегистрации.Вставить("Вид",          "ДополнительнаяОбработка");
	ПараметрыРегистрации.Вставить("Наименование",  "Очистка доступности видов РЦ");
	ПараметрыРегистрации.Вставить("Версия",        "1.0");
	ПараметрыРегистрации.Вставить("БезопасныйРежим", Ложь);
	ПараметрыРегистрации.Вставить("Информация",    "Очистка записей регистра накопления ДоступностьВидовРабочихЦентров за указанный период");

	ТаблицаКоманд = Новый ТаблицаЗначений;
	ТаблицаКоманд.Колонки.Добавить("Идентификатор");
	ТаблицаКоманд.Колонки.Добавить("Представление");
	ТаблицаКоманд.Колонки.Добавить("Использование");

	НоваяКоманда = ТаблицаКоманд.Добавить();
	НоваяКоманда.Идентификатор  = "ОткрытьФорму";
	НоваяКоманда.Представление  = "Очистка доступности видов РЦ";
	НоваяКоманда.Использование  = "ОткрытиеФормы";

	ПараметрыРегистрации.Вставить("Команды", ТаблицаКоманд);

	Возврат ПараметрыРегистрации;

КонецФункции
