////////////////////////////////////////////////////////////////////////////////
// ВНЕШНЯЯ ОБРАБОТКА: Очистка доступности видов рабочих центров
// Модуль управляемой формы
////////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Объект.ДатаНачала    = НачалоМесяца(ТекущаяДатаСеанса());
	Объект.ДатаОкончания = КонецМесяца(ТекущаяДатаСеанса());

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПоказатьДанные(Команда)

	Если НЕ ПроверитьЗаполнение() Тогда
		Возврат;
	КонецЕсли;

	ПоказатьДанныеНаСервере();

КонецПроцедуры

&НаКлиенте
Процедура ОчиститьЗаписиРегистра(Команда)

	Если Объект.ТаблицаДокументов.Количество() = 0 Тогда
		ПоказатьПредупреждение(, "Нет данных для очистки. Сначала нажмите ""Показать данные"".");
		Возврат;
	КонецЕсли;

	ТекстВопроса = "Будет очищено движений по "
		+ Строка(Объект.ТаблицаДокументов.Количество())
		+ " документам. Продолжить?";

	Ответ = Вопрос(ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	Если Ответ = КодВозвратаДиалога.Да Тогда
		КоличествоОчищено = ОчиститьДвиженияНаСервере();
		Предупреждение("Очищены движения по " + КоличествоОчищено + " документам.");
		ПоказатьДанныеНаСервере();
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура УдалитьДокументы(Команда)

	Если Объект.ТаблицаДокументов.Количество() = 0 Тогда
		ПоказатьПредупреждение(, "Нет данных для удаления. Сначала нажмите ""Показать данные"".");
		Возврат;
	КонецЕсли;

	ТекстВопроса = "Будет помечено на удаление "
		+ Строка(Объект.ТаблицаДокументов.Количество())
		+ " документов ""Доступность рабочих центров"". Продолжить?";

	Ответ = Вопрос(ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	Если Ответ = КодВозвратаДиалога.Да Тогда
		КоличествоУдалено = УдалитьДокументыНаСервере();
		Предупреждение("Помечено на удаление " + КоличествоУдалено + " документов.");
		ПоказатьДанныеНаСервере();
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедуры

// === ПОКАЗАТЬ ДАННЫЕ ===

&НаСервере
Процедура ПоказатьДанныеНаСервере()

	Объект.ТаблицаДокументов.Очистить();
	Объект.ТаблицаДвижений.Очистить();

	// 1. Найти документы "ДоступностьВидаРабочихЦентров" за период
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Т.Регистратор КАК Документ,
	|	Т.Регистратор.Дата КАК Дата,
	|	Т.Регистратор.Номер КАК Номер,
	|	Т.ВидРабочегоЦентра КАК ВидРабочегоЦентра,
	|	Т.Регистратор.ПометкаУдаления КАК ПометкаУдаления
	|ИЗ
	|	РегистрНакопления.ДоступностьВидовРабочихЦентров КАК Т
	|ГДЕ
	|	Т.ДатаИнтервала МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И Т.Регистратор ССЫЛКА Документ.ДоступностьРабочихЦентров
	|	И (&ВидРЦПустой ИЛИ Т.ВидРабочегоЦентра = &ВидРЦ)
	|	И (&ПодразделениеПустое ИЛИ Т.Подразделение = &Подразделение)
	|УПОРЯДОЧИТЬ ПО
	|	Дата";

	Запрос.УстановитьПараметр("ДатаНачала",         НачалоДня(Объект.ДатаНачала));
	Запрос.УстановитьПараметр("ДатаОкончания",       КонецДня(Объект.ДатаОкончания));
	Запрос.УстановитьПараметр("ВидРЦ",               Объект.ВидРабочегоЦентра);
	Запрос.УстановитьПараметр("ВидРЦПустой",          НЕ ЗначениеЗаполнено(Объект.ВидРабочегоЦентра));
	Запрос.УстановитьПараметр("Подразделение",        Объект.Подразделение);
	Запрос.УстановитьПараметр("ПодразделениеПустое",  НЕ ЗначениеЗаполнено(Объект.Подразделение));

	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();

	Пока Выборка.Следующий() Цикл
		НоваяСтрока = Объект.ТаблицаДокументов.Добавить();
		НоваяСтрока.Документ            = Выборка.Документ;
		НоваяСтрока.Дата                = Выборка.Дата;
		НоваяСтрока.Номер               = Выборка.Номер;
		НоваяСтрока.ВидРабочегоЦентра   = Выборка.ВидРабочегоЦентра;
		НоваяСтрока.ПометкаУдаления     = Выборка.ПометкаУдаления;
	КонецЦикла;

	// 2. Проверить связанные данные (этапы, заказы, графики)
	ЗапросСвязанных = Новый Запрос;
	ЗапросСвязанных.Текст =
	"ВЫБРАТЬ
	|	ТИПЗНАЧЕНИЯ(Т.Регистратор) КАК ТипРегистратора,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Т.Регистратор) КАК КоличествоДокументов
	|ИЗ
	|	РегистрНакопления.ДоступностьВидовРабочихЦентров КАК Т
	|ГДЕ
	|	Т.ДатаИнтервала МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И НЕ Т.Регистратор ССЫЛКА Документ.ДоступностьРабочихЦентров
	|	И (&ВидРЦПустой ИЛИ Т.ВидРабочегоЦентра = &ВидРЦ)
	|	И (&ПодразделениеПустое ИЛИ Т.Подразделение = &Подразделение)
	|СГРУППИРОВАТЬ ПО
	|	ТИПЗНАЧЕНИЯ(Т.Регистратор)";

	ЗапросСвязанных.УстановитьПараметр("ДатаНачала",         НачалоДня(Объект.ДатаНачала));
	ЗапросСвязанных.УстановитьПараметр("ДатаОкончания",       КонецДня(Объект.ДатаОкончания));
	ЗапросСвязанных.УстановитьПараметр("ВидРЦ",               Объект.ВидРабочегоЦентра);
	ЗапросСвязанных.УстановитьПараметр("ВидРЦПустой",          НЕ ЗначениеЗаполнено(Объект.ВидРабочегоЦентра));
	ЗапросСвязанных.УстановитьПараметр("Подразделение",        Объект.Подразделение);
	ЗапросСвязанных.УстановитьПараметр("ПодразделениеПустое",  НЕ ЗначениеЗаполнено(Объект.Подразделение));

	РезультатСвязанных = ЗапросСвязанных.Выполнить();
	Если НЕ РезультатСвязанных.Пустой() Тогда
		ТекстПредупреждения = "ВНИМАНИЕ! За этот период есть движения от других документов:" + Символы.ПС;
		ВыборкаСвязанных = РезультатСвязанных.Выбрать();
		Пока ВыборкаСвязанных.Следующий() Цикл
			ТекстПредупреждения = ТекстПредупреждения
				+ " - " + Строка(ВыборкаСвязанных.ТипРегистратора)
				+ " (" + Строка(ВыборкаСвязанных.КоличествоДокументов) + " док.)" + Символы.ПС;
		КонецЦикла;
		ТекстПредупреждения = ТекстПредупреждения
			+ "Эти документы НЕ будут затронуты, но учтите их при перезаполнении доступности.";
		Сообщить(ТекстПредупреждения);
	КонецЕсли;

	// 3. Показать движения по регистру за период
	ЗапросДвижений = Новый Запрос;
	ЗапросДвижений.Текст =
	"ВЫБРАТЬ
	|	Т.Регистратор КАК Документ,
	|	Т.ДатаИнтервала КАК ДатаИнтервала,
	|	Т.ВидРабочегоЦентра КАК ВидРабочегоЦентра,
	|	Т.ДоступностьПоВидуРЦ КАК ДоступностьПоВидуРЦ,
	|	Т.ДоступностьПоРЦ КАК ДоступностьПоРЦ,
	|	Т.Занято КАК Занято,
	|	Т.Подразделение КАК Подразделение
	|ИЗ
	|	РегистрНакопления.ДоступностьВидовРабочихЦентров КАК Т
	|ГДЕ
	|	Т.ДатаИнтервала МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И Т.Регистратор ССЫЛКА Документ.ДоступностьРабочихЦентров
	|	И (&ВидРЦПустой ИЛИ Т.ВидРабочегоЦентра = &ВидРЦ)
	|	И (&ПодразделениеПустое ИЛИ Т.Подразделение = &Подразделение)
	|УПОРЯДОЧИТЬ ПО
	|	ДатаИнтервала";

	ЗапросДвижений.УстановитьПараметр("ДатаНачала",         НачалоДня(Объект.ДатаНачала));
	ЗапросДвижений.УстановитьПараметр("ДатаОкончания",       КонецДня(Объект.ДатаОкончания));
	ЗапросДвижений.УстановитьПараметр("ВидРЦ",               Объект.ВидРабочегоЦентра);
	ЗапросДвижений.УстановитьПараметр("ВидРЦПустой",          НЕ ЗначениеЗаполнено(Объект.ВидРабочегоЦентра));
	ЗапросДвижений.УстановитьПараметр("Подразделение",        Объект.Подразделение);
	ЗапросДвижений.УстановитьПараметр("ПодразделениеПустое",  НЕ ЗначениеЗаполнено(Объект.Подразделение));

	РезультатДвижений = ЗапросДвижений.Выполнить();
	ВыборкаДвижений = РезультатДвижений.Выбрать();

	Пока ВыборкаДвижений.Следующий() Цикл
		НоваяСтрока = Объект.ТаблицаДвижений.Добавить();
		НоваяСтрока.Документ              = ВыборкаДвижений.Документ;
		НоваяСтрока.ДатаИнтервала         = ВыборкаДвижений.ДатаИнтервала;
		НоваяСтрока.ВидРабочегоЦентра     = ВыборкаДвижений.ВидРабочегоЦентра;
		НоваяСтрока.ДоступностьПоВидуРЦ   = ВыборкаДвижений.ДоступностьПоВидуРЦ;
		НоваяСтрока.ДоступностьПоРЦ       = ВыборкаДвижений.ДоступностьПоРЦ;
		НоваяСтрока.Занято                = ВыборкаДвижений.Занято;
		НоваяСтрока.Подразделение         = ВыборкаДвижений.Подразделение;
	КонецЦикла;

КонецПроцедуры

// === ОЧИСТИТЬ ДВИЖЕНИЯ ===

&НаСервере
Функция ОчиститьДвиженияНаСервере()

	КоличествоОчищено = 0;

	Для Каждого СтрокаТаблицы Из Объект.ТаблицаДокументов Цикл

		Попытка
			// Очистка движений регистра накопления
			НаборЗаписей = РегистрыНакопления.ДоступностьВидовРабочихЦентров.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Регистратор.Установить(СтрокаТаблицы.Документ);
			НаборЗаписей.Записать(); // Пустой набор = очистка всех движений по документу

			// Очистка движений регистра сведений (если документ также делает движения туда)
			Попытка
				НаборСведений = РегистрыСведений.ДоступностьРабочихЦентров.СоздатьНаборЗаписей();
				НаборСведений.Отбор.Регистратор.Установить(СтрокаТаблицы.Документ);
				НаборСведений.Записать();
			Исключение
				// Если документ не является регистратором этого регистра — пропускаем
			КонецПопытки;

			КоличествоОчищено = КоличествоОчищено + 1;

		Исключение
			Сообщить("Ошибка очистки по документу " + СтрокаТаблицы.Документ + ": "
				+ ОписаниеОшибки());
		КонецПопытки;

	КонецЦикла;

	Возврат КоличествоОчищено;

КонецФункции

// === УДАЛИТЬ ДОКУМЕНТЫ ===

&НаСервере
Функция УдалитьДокументыНаСервере()

	КоличествоУдалено = 0;

	Для Каждого СтрокаТаблицы Из Объект.ТаблицаДокументов Цикл

		Попытка
			ДокОбъект = СтрокаТаблицы.Документ.ПолучитьОбъект();
			Если ДокОбъект <> Неопределено Тогда
				ДокОбъект.УстановитьПометкуУдаления(Истина);
				КоличествоУдалено = КоличествоУдалено + 1;
			КонецЕсли;
		Исключение
			Сообщить("Ошибка пометки на удаление документа " + СтрокаТаблицы.Документ + ": "
				+ ОписаниеОшибки());
		КонецПопытки;

	КонецЦикла;

	Возврат КоличествоУдалено;

КонецФункции

#КонецОбласти
